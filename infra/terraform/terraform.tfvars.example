# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored -- never commit real values.

gcp_project_id       = "capstone-phoenix"
gcp_credentials_file = "~/.gcp/terraform-key.json"
admin_ip_cidr        = "203.0.113.4/32" # curl -s ifconfig.me, then add /32
ssh_public_key        = "ssh-ed25519 AAAA...your-key... collins-capstone"
cluster_name          = "phoenix"
worker_count           = 2
region                 = "us-central1"
zone                   = "us-central1-a"
